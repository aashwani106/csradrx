generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model Event {
  id            String   @id @default(cuid())

  title         String
  url           String

  category      String
  type          String

  repoName      String
  owner         String

  stars         Int?
  releaseTag    String?

  publishedAt   DateTime
  createdAt     DateTime @default(now())

  rawData       Json?
  tweeted       Boolean  @default(false)
  tweetedAt     DateTime?

  analysis      EventAnalysis?
  score         EventScore?
  discordDeliveries DiscordDelivery[]

  @@index([publishedAt])
  @@index([category, type])
  @@index([tweeted, tweetedAt])
  @@unique([url])
}

model ServerConfig {
  id             String   @id @default(cuid())
  guildId        String   @unique
  channelId      String
  enabledGithub  Boolean  @default(true)
  enabledAi      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  deliveries     DiscordDelivery[]

  @@index([guildId, channelId])
}

model DiscordDelivery {
  id             String       @id @default(cuid())
  eventId        String
  serverConfigId String
  deliveredAt    DateTime     @default(now())

  event          Event        @relation(fields: [eventId], references: [id])
  serverConfig   ServerConfig @relation(fields: [serverConfigId], references: [id])

  @@unique([eventId, serverConfigId])
  @@index([serverConfigId, deliveredAt])
}

model EventAnalysis {
  id        String   @id @default(cuid())
  eventId   String   @unique

  event     Event    @relation(fields: [eventId], references: [id])

  summary   String
  keyPoints String[]
  impact    String

  createdAt DateTime @default(now())
}

model EventScore {
  id        String   @id @default(cuid())
  eventId   String   @unique

  event     Event    @relation(fields: [eventId], references: [id])

  score     Float
  createdAt DateTime @default(now())

  @@index([score])
}
